{
	"version": "0.2.0",
	"configurations": [
	
		{
			"name": "asp.net-youtube-course",
			"type": "coreclr",
			"request": "launch",
			"preLaunchTask": "build",
			"program": "${workspaceFolder}/bin/Debug/net8.0/asp.net-youtube-course.dll",
			"args": [],
			"cwd": "${workspaceFolder}",
			"stopAtEntry": false,
			"serverReadyAction": {
				"action": "openExternally",
				"pattern": "\\bNow listening on:\\s+(https?://\\S+)",
				"uriFormat": "%s/swagger"
			},
			"env": {
				"ASPNETCORE_ENVIRONMENT": "Development"
			}
		}
	]
}
